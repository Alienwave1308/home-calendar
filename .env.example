PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/home_calendar
JWT_SECRET=your-secret-key-here
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar-sync/callback
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
ALLOW_PASSWORD_AUTH=false
# Optional: if empty, the first Telegram user who logs in becomes the only master account.
MASTER_TELEGRAM_USER_ID=123456789
MASTER_DISPLAY_NAME=RoVa Epil
MASTER_TIMEZONE=Asia/Novosibirsk
APP_DOMAIN=app.example.com
LETSENCRYPT_EMAIL=admin@example.com
# Address shown in reminder messages (overrides hardcoded default)
SALON_ADDRESS=ул. Примерная, д. 1, кв. 1

# VK Mini App & Bot
VK_APP_ID=your-vk-app-id
VK_APP_SECRET=your-vk-app-secure-key
VK_MINI_APP_SECRET=
VK_OAUTH_SCOPE=phone email
VK_OAUTH_REDIRECT_URI=https://example.com/api/auth/vk-oauth/callback
VK_MINI_ALLOW_UNVERIFIED=false
VK_GROUP_ID=your-vk-group-id
VK_GROUP_TOKEN=your-vk-group-token
VK_SECRET=your-vk-callback-secret
VK_CONFIRMATION_STRING=your-vk-confirmation-string

# Telegram Bot
TELEGRAM_BOT_USERNAME=YourBot
TELEGRAM_API_BASE=https://home-calendar.niggest137.workers.dev

# Web booking launch control
WEB_BOOKING_ENABLED=false
# Optional canary allowlist for browser booking pages, comma-separated: lera,test-master
WEB_BOOKING_ALLOWED_SLUGS=
